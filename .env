# OptimaPay API Configuration
OPTIMA_API_KEY=your_api_key_here
OPTIMA_API_SECRET=your_api_secret_here
OPTIMA_BASE_URL=https://optimapaybridge.co.ke/api/v2/
OPTIMA_PAYMENT_ACCOUNT_ID=17

# Server Configuration
PORT=3000
NODE_ENV=production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
